{
    "redirects": [
        {
            "source": "/api-docs",
            "destination": "/api-docs/",
            "permanent": true
        }
    ],
    "rewrites": [
        {
            "source": "/api-docs/:path*",
            "destination": "https://pld-yh8t.onrender.com/api-docs/:path*"
        },
        {
            "source": "/api/:path*",
            "destination": "https://pld-yh8t.onrender.com/api/:path*"
        },
        {
            "source": "/register",
            "destination": "https://pld-yh8t.onrender.com/register"
        },
        {
            "source": "/verify",
            "destination": "https://pld-yh8t.onrender.com/verify"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}